{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>rancher/renovate-config#release"
  ],
  "baseBranchPatterns": [
    "main"
  ],
  "enabledManagers": [
    "jsonata"
  ],
  "customManagers": [
    /*
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)?( extractVersion=(?<extractVersion>.*?))?\\s+.+_(version|VERSION).*:(\\s|\"|)(?<currentValue>.*)(\"|)",
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?) digestVersion=(?<currentValue>.*)\\s+.+_(sha256|arm64|amd64|arm|s390x).*:(\\s|\"|)(?<currentDigest>.*)(\"|)"
      ]
    },
    */
    {
      "customType": "jsonata",
      "fileFormat": "yaml",
      "managerFilePatterns": ["pkg/rancher-desktop/assets/dependencies.yaml"],
      "matchStrings": ["                                                                           \
        $ . $each(function($v, $n) { $merge([{ 'name': $n }, [$type($v) = 'object'] ? $v]) })      \
        [datasource='github-release-attachments']                                                  \
        .(                                                                                         \
            $dep := $;                                                                             \
            ($keys()[$match($, /^digest_/)])                                                       \
            .({                                                                                    \
                'datasource': $dep.datasource,                                                     \
                'depName': $dep.repo,                                                              \
                'currentValue': $dep.version,                                                      \
                'currentDigest': $lookup($dep, $)                                                  \
            })                                                                                     \
        )                                                                                          \
      "]
    }
  ]
}
